package-as: Preybreaker

curse-id: 1489463
wago-id: vNAg1BKo

ignore:
  # Repository metadata
  - .github
  - .gitattributes
  - .gitignore
  - .pkgmeta

  # Local-only tooling
  - .claude
  - .codex
  - .help
  - .playwright-cli
  - .tmp
  - .vscode

  # Repository-only docs and notes
  - AGENTS.md
  - CHANGELOG.md
  - README.md
  - LICENSE-NOTES.md

  # Development-only addon files
  - PreybreakerTests

manual-changelog: CHANGELOG.md
